# ReqBot local configuration
# Copy this file to .env for local development.

# Safe demo mode. For real LLM calls, set MOCK_LLM=false and configure a provider.
MOCK_LLM=true
LLM_PROVIDER=local

# Gemini production example:
# MOCK_LLM=false
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_api_key_here
# MODEL_NAME=gemini-3.5-flash

# Ollama local example:
# MOCK_LLM=false
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:3b

MAX_TOKENS=4096
GEMINI_TIMEOUT=45
GEMINI_RETRIES=1
OLLAMA_TIMEOUT=45
AGENT2_VALIDATION_USE_LLM=false
AGENT3_USE_LLM=false
REQBOT_HOST=127.0.0.1
REQBOT_PORT=8000
